{
  "name": "chordpro-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://benedikt-jensen.github.io/songbook-editor-react",
  "scripts": {
    "dev": "concurrently \"npm run pdf-server:start\" \"vite\"",
    "ui-only": "vite",
    "serve": "concurrently \"npm run pdf-server:start\" \"serve -s dist\"",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "cross-env VITE_BASE_URL=/songbook-editor-react npm run build",
    "deploy": "gh-pages -d dist",
    "pdf-server:build": "npm run --prefix ./src/pdf-server build",
    "pdf-server:start": "npm run --prefix ./src/pdf-server start"
  },
  "dependencies": {
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.0",
    "@primeuix/themes": "^2.0.0",
    "codemirror": "^6.0.1",
    "gh-pages": "^6.3.0",
    "pagedjs": "^0.4.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss-primeui": "^0.6.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@primevue/auto-import-resolver": "^4.3.1",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "^9.28.0",
    "globals": "^16.2.0",
    "sass": "^1.55.0",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.3",
    "unplugin-vue-components": "^0.27.3",
    "vite": "^7.0.0",
    "vue-tsc": "^2.1.10"
  },
  "allowScripts": {
    "@swc/core@1.12.9": true,
    "esbuild@0.28.1": true,
    "core-js@3.49.0": true
  }
}
